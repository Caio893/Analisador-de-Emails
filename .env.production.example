DEBUG=false
SECRET_KEY=replace-with-a-long-random-django-secret-key
ALLOWED_HOSTS=email-radar.com,api.email-radar.com
BACKEND_URL=https://email-radar.com
FRONTEND_URL=https://email-radar.com
CORS_ALLOWED_ORIGINS=https://email-radar.com
CORS_ALLOW_CREDENTIALS=true
CSRF_TRUSTED_ORIGINS=https://email-radar.com,https://api.email-radar.com
FRONTEND_SITE_ADDRESS=email-radar.com
API_SITE_ADDRESS=api.email-radar.com
CADDY_HTTP_BIND=80
CADDY_HTTPS_BIND=443
BACKEND_BIND=127.0.0.1:8000
FRONTEND_BIND=127.0.0.1:8080
BETA_BASIC_AUTH_ENABLED=true
BETA_BASIC_AUTH_USERNAME=beta
BETA_BASIC_AUTH_PASSWORD=replace-with-a-temporary-beta-password
BETA_BASIC_AUTH_REALM=Email Radar Closed Beta
BETA_BASIC_AUTH_EXEMPT_PATHS=/api/healthz/
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=false

POSTGRES_DB=mailguard
POSTGRES_USER=mailguard
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
DATABASE_ENGINE=postgres

VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_URL=valkey://valkey:6379/0
VALKEY_MAXMEMORY=64mb
VALKEY_SOCKET_CONNECT_TIMEOUT_SECONDS=5
VALKEY_SOCKET_TIMEOUT_SECONDS=10

GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-fernet-key-from-python-cryptography
GOOGLE_TOKEN_ENCRYPTION_FALLBACK_KEYS=
GOOGLE_OAUTH_REDIRECT_URI=https://email-radar.com/api/auth/google/callback/
OAUTHLIB_INSECURE_TRANSPORT=0
GMAIL_SYNC_MAX_RESULTS=25
GMAIL_BODY_CHAR_LIMIT=6000
GMAIL_SYNC_QUERY=
GMAIL_HISTORY_MAX_CHANGES=250
GOOGLE_API_TIMEOUT_SECONDS=15
GMAIL_WATCH_TOPIC=
GMAIL_WATCH_RENEWAL_HOURS=24
ALLOW_ACCOUNT_HEADER_AUTH=false

OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BULK_MODEL=gpt-4.1-mini
OPENAI_ANALYSIS_ENABLED=true
OPENAI_TIMEOUT_SECONDS=30
OPENAI_RETRY_ATTEMPTS=2
OPENAI_RETRY_BASE_SECONDS=1
OPENAI_MAX_OUTPUT_TOKENS=350
OPENAI_BODY_CHAR_LIMIT=3000
OPENAI_PROMPT_VERSION=email-security-v2
OPENAI_DAILY_ANALYSIS_LIMIT=0

ANALYSIS_QUEUE_ENABLED=true
ANALYSIS_QUEUE_AUTO_ENQUEUE=false
ANALYSIS_QUEUE_NAME=mailguard:analysis
ANALYSIS_QUEUE_DEDUP_KEY=mailguard:analysis:queued
ANALYSIS_QUEUE_POP_TIMEOUT=5

VITE_API_BASE_URL=https://email-radar.com/api
VITE_API_WITH_CREDENTIALS=true
VITE_API_TIMEOUT_MS=60000
VITE_EMAIL_SYNC_INTERVAL_MS=300000
VITE_USE_MOCKS=false

DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3
BACKEND_MEM_LIMIT=512m
BACKEND_CPUS=0.75
BACKEND_PIDS_LIMIT=256
ANALYSIS_WORKER_MEM_LIMIT=384m
ANALYSIS_WORKER_CPUS=0.75
ANALYSIS_WORKER_PIDS_LIMIT=128
POSTGRES_MEM_LIMIT=512m
POSTGRES_CPUS=0.75
POSTGRES_PIDS_LIMIT=256
VALKEY_MEM_LIMIT=128m
VALKEY_CPUS=0.25
VALKEY_PIDS_LIMIT=64
FRONTEND_MEM_LIMIT=128m
FRONTEND_CPUS=0.25
FRONTEND_PIDS_LIMIT=64
CADDY_MEM_LIMIT=128m
CADDY_CPUS=0.25
CADDY_PIDS_LIMIT=64
